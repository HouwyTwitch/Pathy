# Copy to .env and adjust.

# Required: password for the bundled Postgres (stores only ciphertext,
# public keys and hashed credentials — but pick a strong one anyway).
POSTGRES_PASSWORD=change-me-to-something-long-and-random

# Host port for the web client + API (default 8080).
PATHY_PORT=8080

# Only needed for `docker compose --profile bots up`: token of a bot you
# created in the web UI (🤖 → Create a bot).
PATHY_BOT_TOKEN=
