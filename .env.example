# Copy to .env and adjust.

# Required: password for the bundled Postgres (stores only ciphertext,
# public keys and hashed credentials — but pick a strong one anyway).
POSTGRES_PASSWORD=change-me-to-something-long-and-random

# Host port for the web client + API (default 8080).
PATHY_PORT=8080

# Only needed for `docker compose --profile bots up`: token of a bot you
# created in the web UI (🤖 → Create a bot).
PATHY_BOT_TOKEN=

# Optional: contact for Web Push (VAPID) — some push services show it to
# users. VAPID keys themselves are generated automatically on first start.
# VAPID_SUBJECT=mailto:you@example.com

# Optional: enables importing sticker packs from Telegram. Any bot token
# from @BotFather works — it is only used to download sticker files.
TELEGRAM_BOT_TOKEN=
